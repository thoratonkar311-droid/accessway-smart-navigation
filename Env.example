# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/accessway?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# ─── Anthropic (Claude AI) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ─── Mapbox ───────────────────────────────────────────────
MAPBOX_TOKEN=pk.eyJ1IjoieW91ciIsImEiOiJ5b3VyLW1hcGJveC10b2tlbiJ9.xxxxx

# ─── File Uploads ─────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ─── Frontend URL (for CORS) ──────────────────────────────
CLIENT_URL=http://localhost:3000
