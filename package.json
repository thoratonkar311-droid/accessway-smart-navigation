{
  "name": "accessway",
  "version": "1.0.0",
  "description": "Smart Accessible Navigation System for wheelchair users",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "client": "cd frontend && npm start",
    "dev:full": "concurrently \"npm run dev\" \"npm run client\"",
    "install:all": "npm install && cd frontend && npm install",
    "seed": "node backend/utils/seed.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.6.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.6.1",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.6.0",
    "express-validator": "^7.0.1",
    "express-rate-limit": "^7.1.4",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "node-geocoder": "^4.2.0",
    "@anthropic-ai/sdk": "^0.20.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
